generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  MANAGER
}

enum ReservationStatus {
  CONFIRMED
  PENDING
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum TableStatus {
  EMPTY
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum CallOutcome {
  ANSWERED
  MISSED
  RESERVATION_INQUIRY
  INFO_REQUEST
}

enum CustomerTag {
  VIP
  REGULAR
  NEW
}

enum ReservationSource {
  PHONE
  INSTAGRAM
  WALK_IN
  WEBSITE
  GOOGLE
  WHATSAPP
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String
  passwordHash String
  role         UserRole    @default(ADMIN)
  sessions     Session[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Session {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  userId      String
  expiresAt   DateTime
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RestaurantSettings {
  id                       String   @id @default(cuid())
  restaurantName           String
  slug                     String   @unique
  phone                    String
  email                    String?
  address                  String?
  openingHours             Json
  seatingCapacity          Int
  averageDiningDurationMin Int      @default(90)
  maxPartySize             Int      @default(12)
  allowWalkIns             Boolean  @default(true)
  requirePhoneVerification Boolean  @default(false)
  reservationLeadTimeDays  Int      @default(30)
  notes                    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Customer {
  id            String        @id @default(cuid())
  name          String
  phone         String        @unique
  email         String?
  notes         String?
  tag           CustomerTag   @default(NEW)
  reservations  Reservation[]
  callLogs      CallLog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([name])
  @@index([tag])
}

model DiningTable {
  id           String        @id @default(cuid())
  number       String        @unique
  label        String
  zone         String
  seatCapacity Int
  status       TableStatus   @default(EMPTY)
  notes        String?
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
}

model Reservation {
  id               String             @id @default(cuid())
  customerId       String
  assignedTableId  String?
  source           ReservationSource  @default(PHONE)
  status           ReservationStatus  @default(PENDING)
  startAt          DateTime
  endAt            DateTime
  guestCount       Int
  occasion         String?
  notes            String?
  createdBy        String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  customer         Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedTable    DiningTable?       @relation(fields: [assignedTableId], references: [id], onDelete: SetNull)
  relatedCalls     CallLog[]

  @@index([startAt])
  @@index([status])
  @@index([assignedTableId])
  @@index([customerId])
}

model CallLog {
  id              String        @id @default(cuid())
  customerId      String?
  reservationId   String?
  phone           String
  callerName      String?
  outcome         CallOutcome
  durationSeconds Int           @default(0)
  notes           String?
  startedAt       DateTime
  createdAt       DateTime      @default(now())
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  reservation     Reservation?  @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([startedAt])
  @@index([outcome])
}
