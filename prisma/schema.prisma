generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  BUSINESS_ADMIN
  STAFF
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum TableArea {
  WINDOW
  ENTRANCE
  GARDEN
  TERRACE
  MAIN_DINING
  VIP
  BAR
  CUSTOM
}

enum TableShape {
  ROUND
  SQUARE
  RECTANGLE
  BOOTH
  BAR
  CUSTOM
}

enum IntegrationProvider {
  WHATSAPP
  INSTAGRAM
  GOOGLE_WEB
  WEBSITE_WIDGET
  AI_ASSISTANT
}

enum IntegrationStatus {
  NOT_CONNECTED
  CONNECTED
  NEEDS_CONFIGURATION
}

enum ReservationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuditCategory {
  AUTH
  SECURITY
  BILLING
  SUPER_ADMIN
  BUSINESS
  WEBHOOK
  RESERVATION
  TABLE
  INTEGRATION
}

enum AuditSeverity {
  INFO
  WARN
  CRITICAL
}

enum BillingProvider {
  PAYTR
}

enum BillingPaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  EXPIRED
}

enum ReservationStatus {
  CONFIRMED
  PENDING
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum TableStatus {
  EMPTY
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum CallOutcome {
  ANSWERED
  MISSED
  RESERVATION_INQUIRY
  INFO_REQUEST
}

enum CustomerTag {
  VIP
  REGULAR
  NEW
}

enum ReservationSource {
  PHONE
  INSTAGRAM
  WALK_IN
  WEBSITE
  GOOGLE
  WHATSAPP
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  businessId   String
  name         String
  passwordHash String
  emailVerifiedAt DateTime?
  role         UserRole    @default(BUSINESS_ADMIN)
  business     Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sessions     Session[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([businessId])
  @@index([role])
}

model PasswordResetToken {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id          String   @id @default(cuid())
  userId      String
  email       String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Business {
  id                    String               @id @default(cuid())
  name                  String
  slug                  String               @unique
  ownerName             String
  ownerEmail            String
  ownerPhone            String
  businessPhone         String
  businessAddress       String?
  city                  String?
  district              String?
  restaurantType        String?
  estimatedTableCount   Int?
  status                BusinessStatus       @default(ACTIVE)
  subscriptionPlan      SubscriptionPlan     @default(STARTER)
  subscriptionStatus    SubscriptionStatus   @default(TRIALING)
  stripeCustomerId      String?              @unique
  stripeSubscriptionId  String?              @unique
  stripePriceId         String?
  trialStartsAt         DateTime?            @default(now())
  trialEndsAt           DateTime?
  subscriptionCurrentPeriodEndsAt DateTime?
  lastPaymentFailedAt   DateTime?
  suspendedAt           DateTime?
  onboardingCompletedAt DateTime?
  notes                 String?
  internalNotes         String?
  lastActivityAt        DateTime?
  users                 User[]
  settings              RestaurantSettings[]
  customers             Customer[]
  tables                DiningTable[]
  reservations          Reservation[]
  callLogs              CallLog[]
  billingPayments       BillingPayment[]
  reservationRequests   ReservationRequest[]
  integrationConnections IntegrationConnection[]
  auditLogs             AuditLog[]
  rateLimits            RateLimitBucket[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([status])
  @@index([subscriptionStatus])
  @@index([ownerEmail])
}

model Session {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  userId      String
  expiresAt   DateTime
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RestaurantSettings {
  id                       String   @id @default(cuid())
  businessId               String
  restaurantName           String
  slug                     String   @unique
  phone                    String
  email                    String?
  address                  String?
  openingHours             Json
  seatingCapacity          Int
  averageDiningDurationMin Int      @default(90)
  maxPartySize             Int      @default(12)
  allowWalkIns             Boolean  @default(true)
  requirePhoneVerification Boolean  @default(false)
  reservationLeadTimeDays  Int      @default(30)
  notes                    String?
  business                 Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([businessId])
  @@index([businessId])
}

model Customer {
  id            String        @id @default(cuid())
  businessId    String
  name          String
  phone         String
  email         String?
  notes         String?
  tag           CustomerTag   @default(NEW)
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  reservations  Reservation[]
  callLogs      CallLog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([businessId, phone])
  @@index([name])
  @@index([tag])
  @@index([businessId])
}

model DiningTable {
  id           String        @id @default(cuid())
  businessId   String
  number       String
  label        String
  zone         String
  area         TableArea     @default(MAIN_DINING)
  shape        TableShape    @default(RECTANGLE)
  seatCapacity Int
  status       TableStatus   @default(EMPTY)
  notes        String?
  archivedAt   DateTime?
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([businessId, number])
  @@index([status])
  @@index([businessId])
}

model Reservation {
  id               String             @id @default(cuid())
  businessId       String
  customerId       String
  guestName        String
  guestPhone       String
  assignedTableId  String?
  source           ReservationSource  @default(PHONE)
  status           ReservationStatus  @default(PENDING)
  startAt          DateTime
  endAt            DateTime
  guestCount       Int
  occasion         String?
  notes            String?
  createdBy        String?
  business         Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  customer         Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedTable    DiningTable?       @relation(fields: [assignedTableId], references: [id], onDelete: SetNull)
  relatedCalls     CallLog[]

  @@index([startAt])
  @@index([status])
  @@index([assignedTableId])
  @@index([customerId])
  @@index([businessId])
}

model CallLog {
  id              String        @id @default(cuid())
  businessId      String
  customerId      String?
  reservationId   String?
  phone           String
  callerName      String?
  outcome         CallOutcome
  durationSeconds Int           @default(0)
  notes           String?
  startedAt       DateTime
  createdAt       DateTime      @default(now())
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  reservation     Reservation?  @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([startedAt])
  @@index([outcome])
  @@index([businessId])
}

model BillingPayment {
  id                   String               @id @default(cuid())
  businessId           String
  provider             BillingProvider      @default(PAYTR)
  plan                 SubscriptionPlan
  status               BillingPaymentStatus @default(PENDING)
  merchantOid          String               @unique
  amountMinor          Int
  collectedAmountMinor Int?
  currency             String               @default("TL")
  requestedByEmail     String
  requestedByName      String?
  testMode             Boolean              @default(false)
  completedAt          DateTime?
  failedAt             DateTime?
  failureReasonCode    String?
  failureReasonMessage String?
  callbackHash         String?
  callbackPayload      Json?
  business             Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([businessId, status])
  @@index([businessId, createdAt])
}

model IntegrationConnection {
  id                String            @id @default(cuid())
  businessId        String
  provider          IntegrationProvider
  status            IntegrationStatus @default(NOT_CONNECTED)
  externalAccountId String?
  config            Json?
  lastSyncedAt      DateTime?
  business          Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([businessId, provider])
  @@index([businessId])
}

model ReservationRequest {
  id                String                   @id @default(cuid())
  businessId        String
  source            ReservationSource
  status            ReservationRequestStatus @default(PENDING)
  guestName         String
  guestPhone        String?
  requestedDate     String?
  requestedTime     String?
  guestCount        Int?
  notes             String?
  extractedData     Json?
  confidenceScore   Float?
  rawMessage        String?
  reviewReason      String?
  approvedReservationId String?
  reviewedByUserId  String?
  business          Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([businessId, status])
  @@index([businessId, source])
}

model AuditLog {
  id           String        @id @default(cuid())
  businessId   String?
  actorUserId  String?
  actorRole    UserRole?
  category     AuditCategory
  severity     AuditSeverity @default(INFO)
  action       String
  targetType   String?
  targetId     String?
  message      String
  ipAddress    String?
  metadata     Json?
  business     Business?     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())

  @@index([businessId, category, createdAt])
  @@index([category, severity, createdAt])
}

model RateLimitBucket {
  id           String   @id @default(cuid())
  businessId    String?
  action       String
  identifier   String
  windowKey    String
  count        Int      @default(0)
  blockedUntil DateTime?
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  business     Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([action, identifier, windowKey])
  @@index([action, identifier])
  @@index([blockedUntil])
}
